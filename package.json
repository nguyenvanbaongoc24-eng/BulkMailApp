{
  "name": "bulkmailapp",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.ca2.automation.pro",
    "productName": "CA2AutomationPro",
    "compression": "maximum",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "services/**/*.js",
      "public/**/*",
      "uploads/.gitkeep",
      ".env",
      "!node_modules/puppeteer/.local-chromium/**/*",
      "!dist/**/*",
      "!src/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CA2 Automation Pro",
      "artifactName": "CA2_Automation_Setup_${version}.${ext}"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "googleapis": "^144.0.0",
    "multer": "^1.4.5-lts.1",
    "puppeteer": "^23.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
